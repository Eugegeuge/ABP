<launch>
    <!-- Set Gazebo Version to Harmonic for ROS 2 Jazzy compatibility -->
    <set_env name="GZ_VERSION" value="harmonic" />

    <let name="urdf_path" value="$(find-pkg-share uav_description)/urdf/uav.xacro"/>
    <let name="world_path" value="$(find-pkg-share uav_gazebo)/worlds/outdoor.world"/>
    <let name="config_file" value="$(find-pkg-share uav_gazebo)/config/bridge.yaml"/>

    <include file="$(find-pkg-share ros_gz_sim)/launch/gz_sim.launch.py">
        <arg name="gz_args" value="-r -v 4 $(var world_path)"/>
    </include>

    <node pkg="robot_state_publisher" exec="robot_state_publisher">
        <param name="robot_description" value="$(command 'xacro $(var urdf_path)')"/>
        <param name="use_sim_time" value="true"/>
    </node>

    <node pkg="ros_gz_sim" exec="create">
        <param name="topic" value="robot_description"/>
        <param name="name" value="uav_drone"/>
        <param name="z" value="0.5"/>
    </node>

    <node pkg="ros_gz_bridge" exec="parameter_bridge">
        <param name="config_file" value="$(var config_file)"/>
        <param name="use_sim_time" value="true"/>
    </node>

    <!-- RViz2 -->
    <node pkg="rviz2" exec="rviz2" args="-d $(find-pkg-share uav_description)/rviz/uav.rviz">
        <param name="use_sim_time" value="true"/>
    </node>
</launch>
